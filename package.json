{
  "name": "app-notifications",
  "version": "1.0.0",
  "description": "Adapter-first TypeScript library for in-app notifications",
  "main": "./dist/cjs/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./supabase": {
      "types": "./dist/types/supabase.d.ts",
      "import": "./dist/esm/supabase.js",
      "require": "./dist/cjs/supabase.js"
    },
    "./sql/supabase-notifications.sql": "./sql/supabase-notifications.sql"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.102.1"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "sql",
    "supabase"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "keywords": [],
  "author": "Amir Eldor <amir@eldor.dev>",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
